{
  "description": "Mix of one concrete and one unresolvable bucket — both appear in substitution",
  "use_state_file": false,
  "expected_resolver": {
    "resource_group_count": 1,
    "bindings": [
      { "service": "s3", "resource_type": "bucket", "binding_names": ["known-bucket", "*"] }
    ]
  },
  "expected_arn_substitutions": [
    {
      "service": "s3",
      "resource_type": "bucket",
      "input_patterns": ["arn:${Partition}:s3:::${BucketName}"],
      "expected_output": ["arn:${Partition}:s3:::known-bucket", "arn:${Partition}:s3:::*"],
      "note": "Concrete name + wildcard for unresolvable expression"
    }
  ]
}
