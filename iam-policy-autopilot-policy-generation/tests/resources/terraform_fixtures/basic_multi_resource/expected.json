{
  "description": "Multi-resource Terraform project with S3, DynamoDB, SQS, Lambda, and IAM — HCL-only resolution (no state file)",
  "use_state_file": false,
  "expected_resolver": {
    "resource_group_count": 5,
    "bindings": [
      { "service": "s3", "resource_type": "bucket", "binding_names": ["my-app-data-bucket", "my-app-logs-bucket"] },
      { "service": "dynamodb", "resource_type": "table", "binding_names": ["users-table"] },
      { "service": "sqs", "resource_type": "queue", "binding_names": ["task-processing-queue"] },
      { "service": "lambda", "resource_type": "function", "binding_names": ["data-processor"] },
      { "service": "iam", "resource_type": "role", "binding_names": ["data-processor-role"] }
    ]
  },
  "expected_arn_substitutions": [
    {
      "service": "s3",
      "resource_type": "bucket",
      "input_patterns": ["arn:${Partition}:s3:::${BucketName}"],
      "expected_output": ["arn:${Partition}:s3:::my-app-data-bucket", "arn:${Partition}:s3:::my-app-logs-bucket"]
    },
    {
      "service": "s3",
      "resource_type": "object",
      "input_patterns": ["arn:${Partition}:s3:::${BucketName}/${ObjectName}"],
      "expected_output": ["arn:${Partition}:s3:::my-app-data-bucket/*", "arn:${Partition}:s3:::my-app-logs-bucket/*"],
      "note": "Sub-resource falls back to parent bucket bindings, appends /*"
    },
    {
      "service": "dynamodb",
      "resource_type": "table",
      "input_patterns": ["arn:${Partition}:dynamodb:${Region}:${Account}:table/${TableName}"],
      "expected_output": ["arn:${Partition}:dynamodb:${Region}:${Account}:table/users-table"]
    },
    {
      "service": "sqs",
      "resource_type": "queue",
      "input_patterns": ["arn:${Partition}:sqs:${Region}:${Account}:${QueueName}"],
      "expected_output": ["arn:${Partition}:sqs:${Region}:${Account}:task-processing-queue"]
    },
    {
      "service": "lambda",
      "resource_type": "function",
      "input_patterns": ["arn:${Partition}:lambda:${Region}:${Account}:function:${FunctionName}"],
      "expected_output": ["arn:${Partition}:lambda:${Region}:${Account}:function:data-processor"]
    },
    {
      "service": "iam",
      "resource_type": "role",
      "input_patterns": ["arn:${Partition}:iam::${Account}:role/${RoleName}"],
      "expected_output": ["arn:${Partition}:iam::${Account}:role/data-processor-role"]
    }
  ],
  "expected_binding_explanations": {
    "expected_arns": [
      "arn:${Partition}:s3:::my-app-data-bucket",
      "arn:${Partition}:s3:::my-app-logs-bucket",
      "arn:${Partition}:dynamodb:${Region}:${Account}:table/users-table",
      "arn:${Partition}:sqs:${Region}:${Account}:task-processing-queue",
      "arn:${Partition}:lambda:${Region}:${Account}:function:data-processor",
      "arn:${Partition}:iam::${Account}:role/data-processor-role"
    ]
  }
}
