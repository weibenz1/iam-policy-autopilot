{
  "Policies": [
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "dynamodb:GetItem",
              "dynamodb:ReadDataForReplication"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:dynamodb:us-east-1:123456789012:table/events-log"
            ]
          },
          {
            "Action": [
              "iam:DeleteServiceLinkedRole",
              "iam:GetRole"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:iam::123456789012:role/event-processor-role"
            ]
          },
          {
            "Action": [
              "kinesis:PutRecord"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kinesis:us-east-1:123456789012:stream/app-events-stream"
            ]
          },
          {
            "Action": [
              "kms:Decrypt",
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "s3.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:Decrypt",
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "sns.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "dynamodb.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "kinesis.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "lambda:InvokeFunction"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:lambda:us-east-1:123456789012:function:event-processor"
            ]
          },
          {
            "Action": [
              "s3-object-lambda:GetObject",
              "s3-object-lambda:PutObject"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::*/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "s3:GetObject",
              "s3:GetObjectLegalHold",
              "s3:GetObjectRetention",
              "s3:GetObjectTagging",
              "s3:GetObjectVersion",
              "s3:PutObject",
              "s3:PutObjectAcl",
              "s3:PutObjectLegalHold",
              "s3:PutObjectRetention",
              "s3:PutObjectTagging"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::app-event-archive/*",
              "arn:aws:s3:::app-results/*",
              "arn:aws:s3:::app-staging-data/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "sns:Publish"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:sns:us-east-1:123456789012:app-notifications"
            ]
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    }
  ],
  "ResourceBindingExplanations": [
    {
      "Arn": "arn:${Partition}:dynamodb:${Region}:${Account}:table/events-log",
      "Location": "main.tf:23.1-31.2",
      "ResourceName": "events_log",
      "ResourceType": "aws_dynamodb_table",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:iam::${Account}:role/event-processor-role",
      "Location": "main.tf:42.1-53.2",
      "ResourceName": "processor_role",
      "ResourceType": "aws_iam_role",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:kinesis:${Region}:${Account}:stream/app-events-stream",
      "Location": "main.tf:1.1-5.2",
      "ResourceName": "events",
      "ResourceType": "aws_kinesis_stream",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:lambda:${Region}:${Account}:function:event-processor",
      "Location": "main.tf:33.1-40.2",
      "ResourceName": "processor",
      "ResourceType": "aws_lambda_function",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:s3:::app-event-archive",
      "Location": "main.tf:11.1-13.2",
      "ResourceName": "archive",
      "ResourceType": "aws_s3_bucket",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:s3:::app-results",
      "Location": "main.tf:19.1-21.2",
      "ResourceName": "results",
      "ResourceType": "aws_s3_bucket",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:s3:::app-staging-data",
      "Location": "main.tf:15.1-17.2",
      "ResourceName": "staging",
      "ResourceType": "aws_s3_bucket",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:sns:${Region}:${Account}:app-notifications",
      "Location": "main.tf:7.1-9.2",
      "ResourceName": "notifications",
      "ResourceType": "aws_sns_topic",
      "Source": "Terraform"
    }
  ]
}
