{
  "Policies": [
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "s3:GetObject"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*",
              "arn:aws:s3:::prod-data-bucket/*"
            ],
            "Sid": "AllowS3GetObject"
          },
          {
            "Action": [
              "s3-object-lambda:GetObject"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*",
              "arn:aws:s3:::*/*"
            ],
            "Sid": "AllowS3GetObject1"
          },
          {
            "Action": [
              "s3:GetObjectLegalHold"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*",
              "arn:aws:s3:::prod-data-bucket/*"
            ],
            "Sid": "AllowS3GetObjectLegalHold2"
          },
          {
            "Action": [
              "s3:GetObjectRetention"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*",
              "arn:aws:s3:::prod-data-bucket/*"
            ],
            "Sid": "AllowS3GetObjectRetention3"
          },
          {
            "Action": [
              "s3:GetObjectTagging"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*",
              "arn:aws:s3:::prod-data-bucket/*"
            ],
            "Sid": "AllowS3GetObjectTagging4"
          },
          {
            "Action": [
              "s3:GetObjectVersion"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*",
              "arn:aws:s3:::prod-data-bucket/*"
            ],
            "Sid": "AllowS3GetObjectVersion5"
          },
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "s3.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ],
            "Sid": "AllowS3Decrypt6"
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    },
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "dynamodb.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ],
            "Sid": "AllowDYNAMODBDecrypt"
          },
          {
            "Action": [
              "dynamodb:PutItem"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:dynamodb:us-east-1:123456789012:table/prod-items-table"
            ],
            "Sid": "AllowDYNAMODBPutItem1"
          },
          {
            "Action": [
              "dynamodb:WriteDataForReplication"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:dynamodb:us-east-1:123456789012:table/prod-items-table"
            ],
            "Sid": "AllowDYNAMODBWriteDataForReplication2"
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    },
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "sqs:SendMessage"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:sqs:us-east-1:123456789012:default-queue"
            ],
            "Sid": "AllowSQSSendMessage"
          },
          {
            "Action": [
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "sqs.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ],
            "Sid": "AllowSQSGenerateDataKey1"
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    }
  ]
}
