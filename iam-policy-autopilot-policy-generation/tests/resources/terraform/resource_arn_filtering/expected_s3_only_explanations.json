{
  "Policies": [
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "dynamodb:GetItem",
              "dynamodb:ReadDataForReplication"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:dynamodb:us-east-1:123456789012:table/users-table"
            ]
          },
          {
            "Action": [
              "iam:DeleteServiceLinkedRole",
              "iam:GetRole"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:iam::123456789012:role/data-processor-role"
            ]
          },
          {
            "Action": [
              "kms:Decrypt",
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "s3.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "dynamodb.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "sqs.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "lambda:InvokeFunction"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:lambda:us-east-1:123456789012:function:data-processor"
            ]
          },
          {
            "Action": [
              "s3-object-lambda:GetObject",
              "s3-object-lambda:PutObject"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::*/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "s3:GetObject",
              "s3:GetObjectLegalHold",
              "s3:GetObjectRetention",
              "s3:GetObjectTagging",
              "s3:GetObjectVersion",
              "s3:PutObject",
              "s3:PutObjectAcl",
              "s3:PutObjectLegalHold",
              "s3:PutObjectRetention",
              "s3:PutObjectTagging"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::my-app-data-bucket/*",
              "arn:aws:s3:::my-app-logs-bucket/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "sqs:SendMessage"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:sqs:us-east-1:123456789012:task-processing-queue"
            ]
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    }
  ],
  "ResourceBindingExplanations": [
    {
      "Arn": "arn:${Partition}:s3:::my-app-data-bucket",
      "Location": "main.tf:5.1-7.2",
      "ResourceName": "data_bucket",
      "ResourceType": "aws_s3_bucket",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:s3:::my-app-logs-bucket",
      "Location": "main.tf:9.1-11.2",
      "ResourceName": "logs_bucket",
      "ResourceType": "aws_s3_bucket",
      "Source": "Terraform"
    }
  ]
}
