{
  "Policies": [
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "dynamodb:PutItem",
              "dynamodb:WriteDataForReplication"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:dynamodb:us-east-1:123456789012:table/items-table"
            ]
          },
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "dynamodb.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "s3.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "sqs.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "s3-object-lambda:GetObject"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::*/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "s3:GetObject",
              "s3:GetObjectLegalHold",
              "s3:GetObjectRetention",
              "s3:GetObjectTagging",
              "s3:GetObjectVersion"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::my-data-bucket/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "sqs:SendMessage"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:sqs:us-east-1:123456789012:task-queue"
            ]
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    }
  ],
  "ResourceBindingExplanations": [
    {
      "Arn": "arn:${Partition}:dynamodb:${Region}:${Account}:table/items-table",
      "Location": "storage.tf:5.1-13.2",
      "ResourceName": "items",
      "ResourceType": "aws_dynamodb_table",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:s3:::my-data-bucket",
      "Location": "storage.tf:1.1-3.2",
      "ResourceName": "data",
      "ResourceType": "aws_s3_bucket",
      "Source": "Terraform"
    },
    {
      "Arn": "arn:${Partition}:sqs:${Region}:${Account}:task-queue",
      "Location": "compute.tf:1.1-3.2",
      "ResourceName": "tasks",
      "ResourceType": "aws_sqs_queue",
      "Source": "Terraform"
    }
  ]
}
