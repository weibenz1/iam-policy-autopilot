{
  "Policies": [
    {
      "Policy": {
        "Id": "IamPolicyAutopilot",
        "Statement": [
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "s3.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "s3:GetObject",
              "s3:GetObjectLegalHold",
              "s3:GetObjectRetention",
              "s3:GetObjectTagging",
              "s3:GetObjectVersion"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::my-data-bucket/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "s3-object-lambda:GetObject"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:s3:::*/*",
              "arn:aws:s3:us-east-1:123456789012:accesspoint/*/object/*"
            ]
          },
          {
            "Action": [
              "kms:Decrypt"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "dynamodb.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "dynamodb:PutItem",
              "dynamodb:WriteDataForReplication"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:dynamodb:us-east-1:123456789012:table/items-table"
            ]
          },
          {
            "Action": [
              "kms:GenerateDataKey"
            ],
            "Condition": {
              "StringEquals": {
                "kms:ViaService": [
                  "sqs.us-east-1.amazonaws.com"
                ]
              }
            },
            "Effect": "Allow",
            "Resource": [
              "arn:aws:kms:us-east-1:123456789012:key/*"
            ]
          },
          {
            "Action": [
              "sqs:SendMessage"
            ],
            "Effect": "Allow",
            "Resource": [
              "arn:aws:sqs:us-east-1:123456789012:task-queue"
            ]
          }
        ],
        "Version": "2012-10-17"
      },
      "PolicyType": "Identity"
    }
  ]
}
