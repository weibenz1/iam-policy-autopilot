# Exclude Java test fixture files from GitHub language statistics.
# These are input samples for Rust unit tests, not production Java code.
iam-policy-autopilot-policy-generation/tests/**/*.java linguist-vendored
iam-policy-autopilot-cli/tests/**/*.java linguist-vendored

# Force LF line endings for test fixture files used in string comparisons.
# Source fixtures are parsed by tree-sitter which preserves line endings in AST nodes.
# JSON/testdata fixtures are compared against serde_json output which always uses \n.
# Git's CRLF conversion on Windows would break assertions for both cases.
**/testdata/** text eol=lf
**/tests/**/*.java text eol=lf
**/tests/**/*.json text eol=lf
**/tests/**/*.py text eol=lf
**/tests/**/*.go text eol=lf
**/tests/**/*.ts text eol=lf
**/tests/**/*.js text eol=lf
